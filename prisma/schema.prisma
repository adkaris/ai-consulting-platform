// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Customer {
  id             String       @id @default(cuid())
  name           String
  industry       String?
  employees      String?      // e.g. "100-500"
  ambitionLevel  Int?         // 1-5
  currentPhase   Int          @default(1) // 1 to 5
  aiTrack        String       @default("GENERAL_AI") // GENERAL_AI | COPILOT | MIXED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assessments         Assessment[]
  copilotAssessments  CopilotAssessment[]
  useCases            UseCase[]
  phaseTasks          PhaseTask[]
  deliverables        Deliverable[]
  documents           Document[]
  changeItems         ChangeManagementItem[]
}

model Assessment {
  id                  String    @id @default(cuid())
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // 8 Core Domains - Maturity Scores (1-5)
  scoreStrategy       Float?
  scoreData           Float?
  scoreTech           Float?
  scoreSecurity       Float?
  scoreSkills         Float?
  scoreOps            Float?
  scoreGovernance     Float?
  scoreFinancial      Float?

  status              String    @default("IN_PROGRESS") // DRAFT, COMPLETED
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UseCase {
  id                  String        @id @default(cuid())
  customerId          String
  customer            Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title               String
  description         String?
  department          String?

  expectedBenefits    String?
  roiEstimate         Float?    // Kept for backward-compat sorting (sum of MONEY rois)
  priority            String?   // HIGH, MEDIUM, LOW
  complexity          Int?      // 1 (simple) to 10 (complex)
  value               Int?      // 1 (low) to 10 (high)

  // PoV fields (Phase 3)
  povTimeframe        String?   // e.g. "8 weeks"
  povSuccessCriteria  String?   // free text
  povNotes            String?

  // Value Realization (Phase 5)
  realizedValue       Float?    // actual captured value to date

  useCaseType         String        @default("GENERAL_AI") // GENERAL_AI | COPILOT
  phase               Int           @default(2)
  status              String        @default("DRAFT") // APPROVED, PILOTING, PRODUCTION

  rois                UseCaseROI[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model UseCaseROI {
  id          String   @id @default(cuid())
  useCaseId   String
  useCase     UseCase  @relation(fields: [useCaseId], references: [id], onDelete: Cascade)

  type        String   // MONEY | PERFORMANCE | TIME
  value       Float
  unit        String   // "€", "%", "hrs/week", "hrs/month", "days/year", "mins/day"
  description String?

  createdAt   DateTime @default(now())
}

model PhaseTask {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phaseNumber Int
  taskKey     String    // e.g. "stakeholder_alignment"
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([customerId, phaseNumber, taskKey])
}

model Deliverable {
  id               String    @id @default(cuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phaseNumber      Int
  deliverableKey   String    // e.g. "readiness_report"
  status           String    @default("PENDING") // PENDING | DRAFT | COMPLETED
  generatedContent String?   // auto-generated markdown draft
  generatedAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([customerId, phaseNumber, deliverableKey])
}

model Document {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phaseNumber Int
  taskKey     String?  // optional: attach to specific subtask
  fileName    String
  fileSize    Int
  mimeType    String
  filePath    String   // relative path under /uploads/
  category    String   @default("OTHER") // CUSTOMER_DOC | DELIVERABLE | MEETING_NOTES | OTHER
  uploadedAt  DateTime @default(now())
}

model ChangeManagementItem {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  category    String   // STAKEHOLDER | LITERACY | RESKILLING | GOVERNANCE | CUSTOM
  title       String
  description String?
  status      String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED | AT_RISK
  owner       String?
  dueDate     String?  // stored as string for flexibility (e.g. "Q3 2025")
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CopilotAssessment {
  id              String    @id @default(cuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // 8 Copilot-specific domain scores (1–5)
  scoreStrategy   Float?    // CP1: Copilot Strategy & Vision
  scoreM365       Float?    // CP2: Microsoft 365 Foundation
  scoreContent    Float?    // CP3: Content & Data Governance
  scoreSecurity   Float?    // CP4: Security & Compliance Readiness
  scoreIdentity   Float?    // CP5: Identity & Access Management
  scoreAdoption   Float?    // CP6: User Adoption & Change Management
  scoreUseCases   Float?    // CP7: Use Case Identification & Value
  scoreGovernance Float?    // CP8: Copilot Governance & Acceptable Use

  status          String    @default("COMPLETED")
  completedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
}

model AssessmentDomain {
  id           String               @id @default(cuid())
  name         String
  description  String?
  weight       Float                @default(1.0)
  trackType    String               @default("GENERAL") // GENERAL | COPILOT
  questions    AssessmentQuestion[]

  @@unique([name])
}

model AssessmentQuestion {
  id           String           @id @default(cuid())
  domainId     String
  domain       AssessmentDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  text         String
  weight       String           @default("Standard") // Critical | High | Standard
  scoringGuide String           @default("{}")      // JSON string mapping score to description
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}
